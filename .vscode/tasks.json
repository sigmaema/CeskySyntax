{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build transpiler",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-File",
                "scripts/build-transpiler.ps1"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run transpiler demo",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-File",
                "scripts/run-demo.ps1"
            ],
            "dependsOn": "build transpiler",
            "problemMatcher": []
        },
        {
            "label": "smoke test",
            "type": "shell",
            "command": "scripts/smoke-test.cmd",
            "dependsOn": "build transpiler",
            "problemMatcher": []
        },
        {
            "label": "translate smoke source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-File",
                "scripts/translate-smoke.ps1"
            ],
            "dependsOn": "build transpiler",
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang++.exe build active file",
            "command": "clang++.exe",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${env:CESKYSYNTAX_TOOLBIN}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}