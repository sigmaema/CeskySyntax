celé číslo číslo rovná se 0
začátek výpisu << "Zadej číslo:" << konec výpisu
zadávání znaků >> číslo
když číslo menší než 67 {
    začátek výpisu << "menší než 67" << konec výpisu
} jinak když číslo rovná se? 67 {
    začátek výpisu << "67" << konec výpisu
} jinak {
    začátek výpisu << "větší než 67" << konec výpisu
}
